<section class="content">
    <div class="row">
        <!-- Danh sách khách đang đợi chat -->
        <div class="col-md-4">
            <div class="box box-solid">
                <div class="box-header with-border"><h3 class="box-title">Khách hàng trực tuyến</h3></div>
                <div class="box-body no-padding">
                    <ul class="nav nav-pills nav-stacked" id="conversation-list">
                        @foreach (var item in Model)
                        {
                            // Nếu GuestSessionId null (do khách đã login), lấy UserId làm định danh tạm
                            var finalId = !string.IsNullOrEmpty(item.GuestSessionId) ? item.GuestSessionId : item.UserId.ToString();

                            <li>
                                <a href="javascript:void(0)"
                                   onclick="loadChat(@item.Id, '@finalId')"
                                   data-session="@finalId"
                                   class="list-group-item conversation-item">
                                    <strong>@(item.User?.UserProfile?.FullName ?? item.User?.Username ?? item.GuestSessionId)</strong>
                                    <span class="badge label-danger unread-count-badge" style="display:none; float:right;">0</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Khung chat chi tiết -->
        <div class="col-md-8">
            <div class="box box-primary direct-chat direct-chat-primary" id="chat-box" style="display:none;">
                <div class="box-header with-border"><h3 class="box-title" id="chat-with">Chat</h3></div>
                <div class="box-body">
                    <div class="direct-chat-messages" id="messagesList" style="height: 400px;">
                        <!-- Tin nhắn sẽ load vào đây -->
                    </div>
                </div>
                <div class="box-footer">
                    <div class="input-group">
                        <input type="text" id="messageInput" placeholder="Nhập nội dung..." class="form-control">
                        <span class="input-group-btn">
                            <button type="button" id="sendButton" class="btn btn-primary btn-flat">Gửi</button>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        // 1. Khai báo biến toàn cục (PHẢI Ở NGOÀI CÙNG)
        var currentGuestSessionId = "";
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        // 2. Hàm loadChat PHẢI ĐỂ NGOÀI document.ready để HTML gọi được
        function loadChat(id, guestSessionId) {
            currentGuestSessionId = guestSessionId;

            // Highlight dòng đang chọn và xóa thông báo
            $(".list-group-item").removeClass("active text-warning font-weight-bold");
            let $activeItem = $(`a[data-session='${guestSessionId}']`);
            $activeItem.addClass("active");
            $activeItem.find(".unread-count-badge").text("0").hide();

            $("#chat-box").show();
            // Clear tin cũ trước khi load mới cho đỡ lag
            $("#messagesList").html('<div class="text-center"><i class="fa fa-spinner fa-spin"></i> Đang tải...</div>');

            $("#messagesList").load("/Admin/Chat/GetMessages/" + id, function () {
                $(this).scrollTop($(this)[0].scrollHeight);
            });
        }

        $(document).ready(function () {
            // 3. Lắng nghe tin nhắn Real-time
            connection.on("ReceiveMessage", function (role, message, time, sId) {
                // Hiển thị tin nếu đang mở đúng người đó HOẶC mình là Admin vừa gửi
                if (sId === currentGuestSessionId || (role === "Admin" && currentGuestSessionId !== "")) {
                    let isMe = (role === "Admin");
                    let html = `
                        <div class="direct-chat-msg ${isMe ? 'right' : ''}">
                            <div class="direct-chat-info clearfix">
                                <span class="direct-chat-name ${isMe ? 'pull-right' : 'pull-left'}">${role}</span>
                                <span class="direct-chat-timestamp ${isMe ? 'pull-left' : 'pull-right'}">${time}</span>
                            </div>
                            <div class="direct-chat-text">${message}</div>
                        </div>`;

                    $("#messagesList").append(html);
                    $("#messagesList").scrollTop($("#messagesList")[0].scrollHeight);
                }

                // Nếu khách khác nhắn thì báo chuông/badge
                if (role !== "Admin" && sId !== currentGuestSessionId) {
                    let $item = $(`a[data-session='${sId}']`);
                    $item.addClass("text-warning font-weight-bold");
                    let $badge = $item.find(".unread-count-badge");
                    let count = parseInt($badge.text()) || 0;
                    $badge.text(count + 1).show();
                }
            });

            // 4. Kết nối Hub
            connection.start().catch(err => console.error("Admin SignalR Error: ", err));

            // 5. Nút gửi
            $("#sendButton").click(function () {
                let msg = $("#messageInput").val();
                if (msg.trim() !== "" && currentGuestSessionId !== "") {
                    connection.invoke("SendMessage", currentGuestSessionId, msg, "", "Admin")
                        .then(() => {
                            $("#messageInput").val("").focus();
                        })
                        .catch(err => console.error(err));
                }
            });

            $("#messageInput").keypress(function (e) {
                if (e.which == 13) { $("#sendButton").click(); e.preventDefault(); }
            });
        });
    </script>
}