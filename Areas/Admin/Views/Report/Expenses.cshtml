@model IEnumerable<Petshop_frontend.Models.Expense>

@{
    ViewData["Title"] = "Quản lý chi phí";
}

<section class="content-header">
    <h1>
        Danh sách Phiếu chi
    </h1>
    <ol class="breadcrumb">
        <li><a href="/Admin/Home"><i class="fa fa-dashboard"></i> Home</a></li>
        <li><a href="/Admin/Report">Báo cáo tài chính</a></li>
        <li class="active">Phiếu chi</li>
    </ol>
</section>

<section class="content">
    <div class="row" style="margin-bottom: 15px;">
        <div class="col-xs-12">
            <a href="@Url.Action("CreateExpense")" class="btn btn-primary"><i class="fa fa-plus"></i> Tạo Phiếu Chỉ Mới</a>
            <a href="@Url.Action("Index")" class="btn btn-default pull-right"><i class="fa fa-bar-chart"></i> Về Bảng điều khiển Tài chính</a>
        </div>
    </div>

    <div class="box box-primary">
        <div class="box-header with-border">
            <h3 class="box-title">Danh sách chi phí</h3>
        </div>
        <div class="box-body table-responsive no-padding">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th>Mã PX</th>
                        <th>Ngày chi</th>
                        <th>Loại chi phí</th>
                        <th>Nội dung</th>
                        <th>Số tiền</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.ExpenseCode</strong></td>
                            <td>@item.ExpenseDate.ToString("dd/MM/yyyy")</td>
                            <td><span class="label label-info">@item.ExpenseType</span></td>
                            <td>@item.Description</td>
                            <td class="text-red font-weight-bold">- @item.Amount.ToString("N0") đ</td>
                            <td>@item.Note</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
