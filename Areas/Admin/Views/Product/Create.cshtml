@model Petshop_frontend.Models.Product
@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<style>
    .field-validation-error {
        color: #dd4b39; /* Màu đỏ của AdminLTE */
        font-style: italic;
        font-size: 0.9em;
        display: block;
        margin-top: 5px;
    }

    .input-validation-error {
        border-color: #dd4b39 !important; /* Đổi màu viền ô input khi có lỗi */
    }
</style>

<section class="content-header">
    <h1>Thêm sản phẩm <small>Thú cưng & Phụ kiện</small></h1>
</section>

<section class="content">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="row">
            <div class="col-md-7">
                <div class="box box-primary">
                    <div class="box-header with-border"><h3 class="box-title">Thông tin cơ bản</h3></div>
                    <div class="box-body">
                        <div class="form-group">
                            <label>Tên sản phẩm (*)</label>
                            <input asp-for="ProductName" class="form-control" placeholder="Nhập tên sản phẩm..." />
                            <span asp-validation-for="ProductName" class="text-danger small"></span>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Danh mục (*)</label>
                                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId" required>
                                        <option value="">-- Chọn danh mục --</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6" style="padding-top:25px">
                                <label>
                                    <input type="checkbox" name="IsPet" id="isPetCheckbox" value="true" @(Model != null && Model.IsPet == true ? "checked" : "") />
                                    <input type="hidden" name="IsPet" value="false" />
                                    Sản phẩm là Thú cưng
                                </label>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Giá bán (VNĐ) (*)</label>
                                    <input asp-for="Price" type="number" class="form-control" placeholder="Ví dụ: 500000" value="" />
                                    <span asp-validation-for="Price" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Số lượng kho (*)</label>
                                    <input asp-for="StockQuantity" type="number" class="form-control" placeholder="Ví dụ: 10" value="" />
                                    <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Ảnh chính sản phẩm (*)</label>
                            <input type="file" name="mainImageFile" class="form-control" accept="image/*" required />
                            <span asp-validation-for="MainImage" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label>Album ảnh bổ sung (Có thể chọn nhiều ảnh cùng lúc)</label>
                            <input type="file" name="moreImages" class="form-control" accept="image/*" multiple />
                            <p class="help-block">Giữ phím Ctrl để chọn nhiều ảnh.</p>
                        </div>
                    </div>
                </div>

                <div class="box box-info">
                    <div class="box-header with-border"><h3 class="box-title">Chương trình giảm giá</h3></div>
                    <div class="box-body">
                        <div class="row">
                            <div class="col-md-4">
                                <label>
                                    <input type="checkbox" name="IsDiscount" value="true" @(Model != null && Model.IsDiscount == true ? "checked" : "")) />
                                    <input type="hidden" name="IsDiscount" value="false" />
                                    Kích hoạt giảm giá
                                </label>
                            </div>
                            <div class="col-md-8">
                                <div class="form-group">
                                    <label>Phần trăm giảm (%)</label>
                                    <input asp-for="DiscountPercent" type="number" class="form-control" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-5" id="petFields" style="display:none;">
                <div class="box box-warning">
                    <div class="box-header with-border"><h3 class="box-title">Thông tin thú cưng</h3></div>
                    <div class="box-body">
                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label>Tháng tuổi</label>
                                <input asp-for="AgeMonths" class="form-control" placeholder="Tháng tuổi" />
                            </div>
                            <div class="col-md-6 form-group">
                                <label>Giới tính</label>
                                <select asp-for="Gender" class="form-control">
                                    <option value="true">Đực</option>
                                    <option value="false">Cái</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Màu lông</label>
                            <input asp-for="FurColor" class="form-control" placeholder="Màu lông" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label>Thông tin bố</label>
                                <input asp-for="FatherInfo" class="form-control" placeholder="Tên/giống bố" />
                            </div>
                            <div class="col-md-6 form-group">
                                <label>Thông tin mẹ</label>
                                <input asp-for="MotherInfo" class="form-control" placeholder="Tên/giống mẹ" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Tính cách</label>
                            <textarea asp-for="Character" class="form-control" rows="2" placeholder="Tính cách"></textarea>
                        </div>

                        <div class="form-group">
                            <label>Nguồn gốc</label>
                            <input asp-for="Origin" class="form-control" placeholder="Nguồn gốc" />
                        </div>
                        <div class="form-group">
                            <label>Sức khỏe</label>
                            <input asp-for="HealthStatus" class="form-control" placeholder="Tốt / Đã tiêm phòng..." />
                        </div>
                        <div class="form-group">
                            <label>
                                <input type="checkbox" name="Dewormed" value="true" @(Model != null && Model.Dewormed == true ? "checked" : "") />
                                <input type="hidden" name="Dewormed" value="false" />
                                Đã tẩy giun
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-12">
                <div class="box box-info">
                    <div class="box-header with-border"><h3 class="box-title">Mô tả chi tiết</h3></div>
                    <div class="box-body">
                        <textarea asp-for="FullDescription" id="editorCreate" class="form-control"></textarea>
                    </div>
                </div>
            </div>

            <div class="col-md-12">
                <div class="box-footer">
                    <button type="submit" class="btn btn-primary">Lưu sản phẩm</button>
                    <a asp-action="Index" class="btn btn-default">Quay lại</a>
                </div>
            </div>
        </div>
    </form>
</section>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            function toggleFields() {
                if ($('#isPetCheckbox').is(':checked')) $('#petFields').fadeIn();
                else $('#petFields').fadeOut();
            }

            $('#isPetCheckbox').change(function () {
                if ($(this).is(':checked')) $('#petFields').slideDown();
                else $('#petFields').slideUp();
            });

            $('#categorySelect').change(function () {
                var text = $(this).find("option:selected").text().toLowerCase();
                if (text.includes("chó") || text.includes("mèo")) {
                    $('#isPetCheckbox').prop('checked', true).change();
                }
            });
            toggleFields();
        });
    </script>

    <script src="https://cdn.ckeditor.com/4.25.1-lts/standard/ckeditor.js"></script>

    <script>
        // Kích hoạt bộ soạn thảo cho cái id="editor"
        CKEDITOR.replace('editor', {
            height: 300,
            removeButtons: 'PasteFromWord' // Tùy chỉnh nút nếu muốn
        });

        // Logic ẩn/hiện trường thú cưng cũ của ông giữ nguyên ở đây
        $('#isPetCheckbox').change(function() {
            if(this.checked) $('#petFields').fadeIn();
            else $('#petFields').fadeOut();
        });
    </script>

}