@model Petshop_frontend.Models.Product

<section class="content-header">
    <h1>Chi tiết sản phẩm: @Model.ProductName</h1>
</section>

<section class="content">
    <div class="row">
        @* Cột trái: Hình ảnh và Mô tả *@
        <div class="col-md-4">
            <div class="box box-primary">
                <div class="box-body box-profile">
                    <img class="img-responsive img-thumbnail" src="@Model.MainImage" alt="Main Image" style="width:100%;">
                    <h3 class="profile-username text-center">@Model.ProductName</h3>
                    <p class="text-muted text-center">@Model.Category?.CategoryName</p>

                    <ul class="list-group list-group-unbordered">
                        <li class="list-group-item">
                            <b>Giá gốc:</b> <a class="pull-right">@((Model.Price ?? 0).ToString("N0")) VNĐ</a>
                        </li>
                        <li class="list-group-item">
                            <b>Giảm giá:</b> <a class="pull-right">@(Model.IsDiscount == true ? Model.DiscountPercent + "%" : "Không")</a>
                        </li>
                        <li class="list-group-item">
                            <b>Giá hiện tại:</b> <a class="pull-right text-red text-bold">@((Model.DiscountPrice ?? Model.Price ?? 0).ToString("N0")) VNĐ</a>
                        </li>
                        <li class="list-group-item">
                            <b>Số lượng kho:</b> <a class="pull-right">@Model.StockQuantity</a>
                        </li>
                    </ul>
                </div>
            </div>

            @* Album ảnh bổ sung *@
            <div class="box box-primary">
                <div class="box-header with-border"><h3 class="box-title">Album ảnh</h3></div>
                <div class="box-body">
                    <div class="row">
                        @foreach (var img in Model.ProductImages)
                        {
                            <div class="col-xs-6" style="margin-bottom:10px;">
                                <img src="@img.ImageUrl" class="img-thumbnail" style="height:80px; width:100%; object-fit:cover;">
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Cột phải: Thông tin chi tiết *@
        <div class="col-md-8">
            <div class="nav-tabs-custom">
                <ul class="nav nav-tabs">
                    <li class="active"><a href="#description" data-toggle="tab">Mô tả chi tiết</a></li>
                    @if (Model.IsPet == true)
                    {
                        <li><a href="#pet-info" data-toggle="tab">Đặc điểm thú cưng</a></li>
                    }
                </ul>
                <div class="tab-content">
                    @* Tab Mô tả *@
                    <div class="active tab-pane" id="description">
                        @if (!string.IsNullOrEmpty(Model.FullDescription))
                        {
                            @* Dùng Html.Raw vì nội dung lưu dưới dạng HTML từ CKEditor *@
                            <div>@Html.Raw(Model.FullDescription)</div>
                        }
                        else
                        {
                            <p class="text-muted">Chưa có mô tả cho sản phẩm này.</p>
                        }
                    </div>

                    @* Tab Thú cưng *@
                    @if (Model.IsPet == true)
                    {
                        <div class="tab-pane" id="pet-info">
                            <table class="table table-bordered">
                                <tr><th width="30%">Tháng tuổi</th><td>@Model.AgeMonths</td></tr>
                                <tr><th>Giới tính</th><td>@(Model.Gender == true ? "Đực" : "Cái")</td></tr>
                                <tr><th>Màu lông</th><td>@Model.FurColor</td></tr>
                                <tr><th>Sức khỏe</th><td>@Model.HealthStatus</td></tr>
                                <tr><th>Nguồn gốc</th><td>@Model.Origin</td></tr>
                                <tr><th>Đã tẩy giun</th><td>@(Model.Dewormed == true ? "Rồi" : "Chưa")</td></tr>
                                <tr><th>Thông tin bố mẹ</th><td>Bố: @Model.FatherInfo | Mẹ: @Model.MotherInfo</td></tr>
                                <tr><th>Tính cách</th><td>@Model.Character</td></tr>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div style="margin-top: 20px;">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="fa fa-edit"></i> Chỉnh sửa</a>
                <a asp-action="Index" class="btn btn-default"><i class="fa fa-list"></i> Quay lại danh sách</a>
            </div>
        </div>
    </div>
</section>