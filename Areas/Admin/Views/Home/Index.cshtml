@model dynamic
@* Sau này bạn sẽ truyền AdminDashboardVM vào đây, tạm thời dùng dynamic để test giao diện *@

@{
    ViewData["Title"] = "Bảng điều khiển";
}

<!-- Content Header (Page header) -->
<section class="content-header">
    <h1>
        Bảng điều khiển
        <small>Hệ thống quản lý ManaPet</small>
    </h1>
    <ol class="breadcrumb">
        <li><a href="#"><i class="fa fa-dashboard"></i> Home</a></li>
        <li class="active">Dashboard</li>
    </ol>
</section>

<!-- Main content -->
<section class="content">
    <!-- 4 Cái Hộp Thông Tin (Info boxes) -->
    <div class="row">
        <div class="col-lg-3 col-xs-6">
            <div class="small-box bg-aqua">
                <div class="inner">
                    <h3>150</h3>
                    <p>Đơn hàng mới</p>
                </div>
                <div class="icon">
                    <i class="ion ion-bag"></i>
                </div>
                <a href="#" class="small-box-footer">Xem chi tiết <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
        <div class="col-lg-3 col-xs-6">
            <div class="small-box bg-green">
                <div class="inner">
                    <h3>53<sup style="font-size: 20px">%</sup></h3>
                    <p>Tăng trưởng doanh thu</p>
                </div>
                <div class="icon">
                    <i class="ion ion-stats-bars"></i>
                </div>
                <a href="#" class="small-box-footer">Báo cáo tài chính <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
        <div class="col-lg-3 col-xs-6">
            <div class="small-box bg-yellow">
                <div class="inner">
                    <h3>44</h3>
                    <p>Khách hàng đăng ký</p>
                </div>
                <div class="icon">
                    <i class="ion ion-person-add"></i>
                </div>
                <a asp-area="Admin" asp-controller="User" asp-action="Index" class="small-box-footer">Danh sách User <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
        <div class="col-lg-3 col-xs-6">
            <div class="small-box bg-red">
                <div class="inner">
                    <h3>15</h3>
                    <p>Sản phẩm hết hàng</p>
                </div>
                <div class="icon">
                    <i class="ion ion-pie-graph"></i>
                </div>
                <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="small-box-footer">Kiểm tra kho <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Cột bên trái: Danh sách đơn hàng mới -->
        <div class="col-md-8">
            <div class="box box-info">
                <div class="box-header with-border">
                    <h3 class="box-title">Đơn hàng mới nhất</h3>
                    <div class="box-tools pull-right">
                        <button type="button" class="btn btn-box-tool" data-widget="collapse"><i class="fa fa-minus"></i></button>
                    </div>
                </div>
                <div class="box-body">
                    <div class="table-responsive">
                        <table class="table no-margin">
                            <thead>
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Sản phẩm/Thú cưng</th>
                                    <th>Trạng thái</th>
                                    <th>Giá trị</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><a href="#">OR9842</a></td>
                                    <td>Chó Poodle Tiny</td>
                                    <td><span class="label label-success">Đã giao</span></td>
                                    <td>4.500.000đ</td>
                                </tr>
                                <tr>
                                    <td><a href="#">OR1848</a></td>
                                    <td>Thức ăn mèo Me-O</td>
                                    <td><span class="label label-warning">Chờ xử lý</span></td>
                                    <td>120.000đ</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="box-footer clearfix">
                    <a href="javascript:void(0)" class="btn btn-sm btn-default btn-flat pull-right">Xem tất cả đơn hàng</a>
                </div>
            </div>
        </div>

        <!-- Cột bên phải: Sản phẩm/Thú cưng mới thêm -->
        <div class="col-md-4">
            <div class="box box-primary">
                <div class="box-header with-border">
                    <h3 class="box-title">Thú cưng mới nhập kho</h3>
                </div>
                <div class="box-body">
                    <ul class="products-list product-list-in-box">
                        <li class="item">
                            <div class="product-img">
                                <img src="/dist/img/default-50x50.gif" alt="Product Image">
                            </div>
                            <div class="product-info">
                                <a href="javascript:void(0)" class="product-title">Mèo Anh Lông Ngắn <span class="label label-warning pull-right">8.000.000đ</span></a>
                                <span class="product-description">Màu xám xanh, 3 tháng tuổi.</span>
                            </div>
                        </li>
                    </ul>
                </div>
                <div class="box-footer text-center">
                    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="uppercase">Xem tất cả thú cưng</a>
                </div>
            </div>
        </div>
    </div>
</section>