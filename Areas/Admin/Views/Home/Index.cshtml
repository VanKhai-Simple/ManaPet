@model AdminDashboardVM

@{
    ViewData["Title"] = "Bảng điều khiển";
}

<section class="content-header">
    <h1>
        Bảng điều khiển
        <small>Hệ thống ManaPet - Chào Admin!</small>
    </h1>
</section>

<section class="content">
    <div class="row">
        <div class="col-lg-3 col-xs-6">
            <div class="small-box bg-aqua">
                <div class="inner">
                    <h3>@Model.NewOrdersCount</h3>
                    <p>Đơn hàng mới</p>
                </div>
                <div class="icon"><i class="fa fa-shopping-cart"></i></div>
                <a asp-controller="Orders" asp-action="Index" class="small-box-footer">Xử lý ngay <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
        <div class="col-lg-3 col-xs-6">
            <div class="small-box bg-green">
                <div class="inner">
                    <h3>@Model.RevenueGrowth<sup style="font-size: 20px">%</sup></h3>
                    <p>Tăng trưởng tháng</p>
                </div>
                <div class="icon"><i class="fa fa-line-chart"></i></div>
                <a asp-controller="Finance" asp-action="Index" class="small-box-footer">Xem báo cáo <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
        <div class="col-lg-3 col-xs-6">
            <div class="small-box bg-yellow">
                <div class="inner">
                    <h3>@Model.TotalUsers</h3>
                    <p>Khách hàng hệ thống</p>
                </div>
                <div class="icon"><i class="fa fa-user-plus"></i></div>
                <a asp-controller="Customer" asp-action="Index" class="small-box-footer">Quản lý User <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
        <div class="col-lg-3 col-xs-6">
            <div class="small-box bg-red">
                <div class="inner">
                    <h3>@Model.OutOfStockCount</h3>
                    <p>Sản phẩm hết hàng</p>
                </div>
                <div class="icon"><i class="fa fa-warning"></i></div>
                <a asp-controller="Products" asp-action="Index" class="small-box-footer">Nhập kho ngay <i class="fa fa-arrow-circle-right"></i></a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="box box-info shadow border-radius-10">
                <div class="box-header with-border">
                    <h3 class="box-title fw-bold">Đơn hàng mới nhất</h3>
                </div>
                <div class="box-body">
                    <div class="table-responsive">
                        <table class="table no-margin table-hover">
                            <thead>
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Khách hàng</th>
                                    <th>Trạng thái</th>
                                    <th>Tổng tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.LatestOrders)
                                {
                                    <tr>
                                        <td><a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="text-primary fw-bold">#@order.Id</a></td>
                                        <td>@order.FullName</td>
                                        <td>
                                            @if (order.Status == "Đã thanh toán")
                                            {
                                                <span class="label label-success">@order.Status</span>
                                            }
                                            else if (order.Status == "Chờ xác nhận")
                                            {
                                                <span class="label label-warning">@order.Status</span>
                                            }
                                            else
                                            {
                                                <span class="label label-default">@order.Status</span>
                                            }
                                        </td>
                                        <td class="text-danger fw-bold">@(((decimal)order.TotalAmount).ToString("N0"))đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="box-footer text-center">
                    <a asp-controller="OrderAdmin" asp-action="Index" class="uppercase">Xem tất cả đơn hàng</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="box box-primary shadow border-radius-10">
                <div class="box-header with-border">
                    <h3 class="box-title fw-bold">Vừa nhập kho</h3>
                </div>
                <div class="box-body">
                    <ul class="products-list product-list-in-box">
                        @foreach (var p in Model.LatestProducts)
                        {
                            <li class="item">
                                <div class="product-img">
                                    <img src="@p.MainImage" alt="Product Image" class="rounded" style="width: 50px; height: 50px; object-fit: cover;">
                                </div>
                                <div class="product-info">
                                    <a href="#" class="product-title">
                                        @p.ProductName
                                        <span class="label label-info pull-right">@(((decimal)p.Price).ToString("N0"))đ</span>
                                    </a>
                                    <span class="product-description text-truncate" style="max-width: 200px;">
                                        Kho: @p.StockQuantity | @p.FullDescription
                                    </span>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
                <div class="box-footer text-center">
                    <a asp-controller="Product" asp-action="Index" class="uppercase">Quản lý kho hàng</a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .shadow {
        box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
    }

    .border-radius-10 {
        border-radius: 10px !important;
    }

    .table th {
        border-top: none !important;
        color: #777;
        font-size: 0.85rem;
        text-transform: uppercase;
    }
</style>