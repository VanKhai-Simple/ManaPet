@model Petshop_frontend.Models.Product
@{
    ViewData["Title"] = "Cập Nhật Thú Cưng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<section class="content-header">
    <h1>
        Sửa Thú Cưng: #PET-@Model.Id.ToString("D3")
    </h1>
    <ol class="breadcrumb">
        <li><a href="/Admin"><i class="fa fa-dashboard"></i> Home</a></li>
        <li><a href="/Admin/Pet">Thú Cưng</a></li>
        <li class="active">Cập nhật</li>
    </ol>
</section>

<section class="content">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="IsPet" />

        <div class="row">
            <!-- Cột Trái -->
            <div class="col-md-8">
                <!-- THÔNG TIN CƠ BẢN -->
                <div class="box box-primary">
                    <div class="box-header with-border">
                        <h3 class="box-title">Thông Tin Cơ Bản</h3>
                        <div class="box-tools pull-right">
                            <a href="/Admin/Pet" class="btn btn-box-tool text-muted"><i class="fa fa-arrow-left"></i> Trở về</a>
                        </div>
                    </div>
                    <div class="box-body">
                        <div class="form-group">
                            <label>Tên thú cưng <span class="text-danger">*</span></label>
                            <input asp-for="ProductName" class="form-control" required />
                        </div>

                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>Loài / Giống</label>
                                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                                        <option value="">-- Chọn giống loài --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label>Tuổi (Tháng)</label>
                                    <input asp-for="AgeMonths" type="number" class="form-control" />
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label>Giới tính</label>
                                    <select asp-for="Gender" class="form-control">
                                        <option value="true">Đực</option>
                                        <option value="false">Cái</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>Màu sắc lông</label>
                                    <input asp-for="FurColor" class="form-control" />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>Nguồn gốc / Phả hệ</label>
                                    <input asp-for="Origin" class="form-control" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ĐẶC TẢ CHI TIẾT -->
                <div class="box box-info">
                    <div class="box-header with-border">
                        <h3 class="box-title">Đặc Tả Chi Tiết</h3>
                    </div>
                    <div class="box-body">
                        <div class="form-group">
                            <label>Tính cách & Thói quen</label>
                            <textarea asp-for="Character" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="form-group">
                            <label>Mô tả chi tiết / Chế độ chăm sóc</label>
                            <textarea asp-for="FullDescription" class="form-control" rows="4"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cột Phải -->
            <div class="col-md-4">
                
                <!-- BÁN HÀNG -->
                <div class="box box-success">
                    <div class="box-header with-border">
                        <h3 class="box-title">Bán Hàng</h3>
                    </div>
                    <div class="box-body">
                        <div class="form-group">
                            <label>Giá bán (VNĐ) <span class="text-danger">*</span></label>
                            <input asp-for="Price" type="number" class="form-control" style="font-size: 18px; font-weight: bold; color: #dd4b39;" required />
                        </div>
                        <div class="form-group">
                            <label>Số lượng hiện tại</label>
                            <input asp-for="StockQuantity" type="number" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Tình trạng buôn bán</label>
                            <select asp-for="Condition" class="form-control">
                                <option value="Còn bán">✅ Còn bán</option>
                                <option value="Đang giữ chỗ">⏳ Đang giữ chỗ</option>
                                <option value="Đã bán">❌ Đã bán</option>
                                <option value="Ngừng kinh doanh">⛔ Ngừng kinh doanh</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- HỒ SƠ Y TẾ -->
                <div class="box box-warning">
                    <div class="box-header with-border">
                        <h3 class="box-title"><i class="fa fa-heartbeat"></i> Y Tế</h3>
                    </div>
                    <div class="box-body">
                        <div class="form-group">
                            <div class="checkbox">
                                <label>
                                    <input type="checkbox" name="Dewormed" value="true" @(Model != null && Model.Dewormed == true ? "checked" : "")> <b>Đã tẩy giun</b>
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Tình trạng Tiêm phòng / Sức khỏe</label>
                            <input asp-for="HealthStatus" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- HÌNH ẢNH -->
                <div class="box box-danger">
                    <div class="box-header with-border">
                        <h3 class="box-title">Hình Ảnh</h3>
                    </div>
                    <div class="box-body">
                        <div class="form-group">
                            <label>Link URL Ảnh đại diện</label>
                            <input asp-for="MainImage" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-warning btn-block btn-lg"><i class="fa fa-pencil"></i> LƯU THAY ĐỔI</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</section>
