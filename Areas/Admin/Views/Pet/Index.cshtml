@model IEnumerable<Petshop_frontend.Models.Product>
@{
    ViewData["Title"] = "Quản lý Thú Cưng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .badge-con-ban { background-color: #00a65a; color: white; padding: 5px 10px; border-radius: 4px;} /* Sucess */
    .badge-giu-cho { background-color: #f39c12; color: white; padding: 5px 10px; border-radius: 4px; } /* Warning */
    .badge-da-ban { background-color: #dd4b39; color: white; padding: 5px 10px; border-radius: 4px; } /* Danger */
    .badge-ngung-ban { background-color: #605ca8; color: white; padding: 5px 10px; border-radius: 4px; } /* Purple */
</style>

<!-- Content Header -->
<section class="content-header">
    <h1>
        Quản lý Thú Cưng
        <small>Control panel</small>
    </h1>
    <ol class="breadcrumb">
        <li><a href="/Admin"><i class="fa fa-dashboard"></i> Home</a></li>
        <li class="active">Thú Cưng</li>
    </ol>
</section>

<!-- Main content -->
<section class="content">
    <!-- KHỐI THỐNG KÊ NHANH (AdminLTE Info Boxes) -->
    <div class="row">
        <div class="col-md-3 col-sm-6 col-xs-12">
            <div class="info-box">
                <span class="info-box-icon bg-aqua"><i class="fa fa-paw"></i></span>
                <div class="info-box-content">
                    <span class="info-box-text">TỔNG THÚ CƯNG</span>
                    <span class="info-box-number">@ViewBag.TotalPets</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 col-xs-12">
            <div class="info-box">
                <span class="info-box-icon bg-green"><i class="fa fa-check"></i></span>
                <div class="info-box-content">
                    <span class="info-box-text">ĐANG BÁN</span>
                    <span class="info-box-number">@ViewBag.SellingPets</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 col-xs-12">
            <div class="info-box">
                <span class="info-box-icon bg-red"><i class="fa fa-shopping-cart"></i></span>
                <div class="info-box-content">
                    <span class="info-box-text">ĐÃ BÁN</span>
                    <span class="info-box-number">@ViewBag.SoldPets</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 col-xs-12">
            <div class="info-box">
                <span class="info-box-icon bg-yellow"><i class="fa fa-clock-o"></i></span>
                <div class="info-box-content">
                    <span class="info-box-text">GIỮ CHỖ & SẮP HẾT</span>
                    <span class="info-box-number">@(ViewBag.PendingPets + ViewBag.LowStockPets)</span>
                </div>
            </div>
        </div>
    </div>

    <!-- KHỐI TABS VÀ TABLE -->
    <div class="row">
        <div class="col-xs-12">
            <div class="nav-tabs-custom">
                <ul class="nav nav-tabs">
                    <li class="active"><a href="#list_pane" data-toggle="tab"><b>Danh sách thú cưng</b></a></li>
                    <li><a href="#category_pane" data-toggle="tab"><b>Loài & Giống</b></a></li>
                    <li><a href="#health_pane" data-toggle="tab"><b>Sức khỏe & Tiêm phòng</b></a></li>
                    <li class="pull-right">
                        <a href="/Admin/Pet/Create" class="text-muted"><i class="fa fa-plus text-primary"></i> <b class="text-primary">TẠO MỚI</b></a>
                    </li>
                </ul>

                <div class="tab-content">
                    <!-- TAB 1: DANH SÁCH -->
                    <div class="tab-pane active" id="list_pane">
                        
                        <!-- Bộ Lọc -->
                        <div class="row" style="margin-bottom: 15px;">
                            <div class="col-sm-4">
                                <input type="text" class="form-control" placeholder="Tìm tên, mã thú cưng..." />
                            </div>
                            <div class="col-sm-3">
                                <select class="form-control">
                                    <option value="">Tất cả trạng thái</option>
                                    <option value="Còn bán">Còn bán</option>
                                    <option value="Đã bán">Đã bán</option>
                                    <option value="Đang giữ chỗ">Đang giữ chỗ</option>
                                </select>
                            </div>
                        </div>

                        <!-- Table -->
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Mã TC</th>
                                        <th>Ảnh</th>
                                        <th>Tên thú cưng</th>
                                        <th>Giống</th>
                                        <th>Tuổi</th>
                                        <th>Giá bán</th>
                                        <th>Tình trạng</th>
                                        <th style="text-align: right;">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if(Model != null && Model.Any())
                                    {
                                        foreach(var item in Model)
                                        {
                                            <tr>
                                                <td style="font-weight: bold; color: #666;">#PET-@item.Id.ToString("D3")</td>
                                                <td>
                                                    <img src="@(!string.IsNullOrEmpty(item.MainImage) ? item.MainImage : "/Images/pet.jpg")" onerror="this.src='/Images/logo-mana-pet.png';" alt="@item.ProductName" width="50" height="50" style="border-radius: 4px; object-fit: cover;"/>
                                                </td>
                                                <td style="font-weight: bold; color: #3c8dbc;">@item.ProductName</td>
                                                <td>@(item.Category != null ? item.Category.CategoryName : "Chưa phân loại")</td>
                                                <td>@(item.AgeMonths) tháng</td>
                                                <td style="font-weight: bold; color: #dd4b39;">@item.Price.ToString("N0") ₫</td>
                                                <td>
                                                    @{
                                                        var statusClass = item.Condition == "Đã bán" ? "badge-da-ban" :
                                                                          item.Condition == "Đang giữ chỗ" ? "badge-giu-cho" :
                                                                          item.Condition == "Ngừng kinh doanh" ? "badge-ngung-ban" : "badge-con-ban";
                                                        
                                                        var statusText = string.IsNullOrEmpty(item.Condition) ? "Còn bán" : item.Condition;
                                                    }
                                                    <span class="@statusClass">@statusText</span>
                                                </td>
                                                <td style="text-align: right;">
                                                    <a href="#" class="btn btn-sm btn-info" title="Xem"><i class="fa fa-eye"></i></a>
                                                    <a href="/Admin/Pet/Edit/@item.Id" class="btn btn-sm btn-primary" title="Sửa"><i class="fa fa-edit"></i></a>
                                                    <form action="/Admin/Pet/SoftDelete" method="post" style="display:inline;">
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Ngừng kinh doanh thú cưng này?');"><i class="fa fa-trash"></i></button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="8" class="text-center text-muted" style="padding: 30px;">Chưa có thú cưng nào. Hãy bấm TẠO MỚI ngay!</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div><!-- /.tab-pane -->

                    <!-- TAB 2: Loài Giống -->
                    <div class="tab-pane" id="category_pane">
                        <div style="padding: 15px;">
                            <h4 class="text-primary">Quản lý Phân loại Giống Loài</h4>
                            <p class="text-muted">Tính năng hiển thị giống chó/mèo (Category Table) sẽ được tích hợp tại đây.</p>
                        </div>
                    </div><!-- /.tab-pane -->

                    <!-- TAB 3: Sức khỏe -->
                    <div class="tab-pane" id="health_pane">
                        <div style="padding: 15px;">
                            <h4 class="text-success">Theo Dõi Cột Mốc Y Tế</h4>
                            <p class="text-muted">Danh sách thú cưng cần tẩy giun / tiêm phòng vắc xin tháng này.</p>
                        </div>
                    </div><!-- /.tab-pane -->
                </div><!-- /.tab-content -->
            </div>
        </div>
    </div>
</section>
