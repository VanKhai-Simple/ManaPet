@model Petshop_frontend.Models.Order

<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Chi tiết đơn hàng #@Model.Id</h4>
            <span class="badge bg-light text-primary">@Model.Status</span>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h5 class="text-muted border-bottom pb-2">Thông tin người nhận</h5>
                    <p><strong>Họ tên:</strong> @Model.FullName</p>
                    <p><strong>Số điện thoại:</strong> @Model.PhoneNumber</p>
                    <p><strong>Địa chỉ:</strong> @Model.Address</p>
                    <p><strong>Ghi chú:</strong> @(string.IsNullOrEmpty(Model.Note) ? "Không có" : Model.Note)</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <h5 class="text-muted border-bottom pb-2">Thông tin thanh toán</h5>
                    <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Tổng cộng:</strong> <span class="text-danger fs-4 fw-bold">@Model.TotalAmount?.ToString("N0") VNĐ</span></p>
                </div>
            </div>

            <h5 class="text-muted border-bottom pb-2">Danh sách sản phẩm</h5>
            <table class="table table-borderless">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in Model.OrderDetails)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="@detail.Product.MainImage" alt="@detail.Product.ProductName" style="width: 50px; height: 50px; object-fit: cover; margin-right: 15px;" class="rounded">
                                    <span>@detail.Product.ProductName</span>
                                </div>
                            </td>
                            <td class="text-center">@detail.Quantity</td>
                            <td class="text-end">@detail.Price.ToString("N0") đ</td>
                            <td class="text-end fw-bold">@((detail.Price * detail.Quantity).ToString("N0")) đ</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="mt-4">
                <a asp-action="MyOrders" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>

                @if (Model.Status == "Chờ xác nhận")
                {
                    <button type="button" class="btn btn-outline-danger" onclick="confirmCancel(@Model.Id)">
                        Hủy đơn hàng
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmCancel(id) {
            if (confirm("Bạn có chắc chắn muốn hủy đơn hàng này không?")) {
                // Gửi form hoặc gọi ajax để hủy
                alert("Yêu cầu hủy đơn #" + id + " đã được gửi!");
            }
        }
    </script>
}