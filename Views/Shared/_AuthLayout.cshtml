<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ManaPet Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    @* Google font *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

    <style>
        
        body {
			font-family: 'Roboto', sans-serif !important;
            background-color: #f8f9fa;
            display: flex;
            align-items: center;
            min-height: 100vh;
        }

        .auth-card {
            border-radius: 15px;
            border: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            overflow: hidden;
        }

        .auth-header {
            background: #0d6efd;
            color: white;
            padding: 2rem;
            text-align: center;
        }

        .auth-body {
            padding: 2.5rem;
            background: white;
        }

        .btn-auth {
            border-radius: 50px;
            padding: 10px 20px;
            font-weight: 600;
        }

        /*    Login and Register  -- start */
        /* Viền đỏ cho ô nhập liệu khi bị lỗi validate */
        input.input-validation-error {
            border: 2px solid #dc3545 !important;
            background-color: #fff8f8;
        }

        /* Hiệu ứng mờ dần cho thông báo lỗi */
        span.field-validation-error {
            display: block;
            margin-top: 5px;
            font-size: 0.85rem;
            font-weight: 500;
        }

        /*    Login and Register  -- end  */
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="auth-card">
                    <div class="auth-header">
                        <h2 class="mb-0">🐾 ManaPet</h2>
                        <small>Cửa hàng thú cưng & Phụ kiện</small>
                    </div>
                    <div class="auth-body">
                        @RenderBody()
                    </div>
                </div>
                <div class="text-center mt-3">
                    <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small">
                        ← Quay về trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>