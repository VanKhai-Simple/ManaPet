<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Mana Pet</title>

    <link rel="icon" type="image/png" href="~/Images/logo-mana-pet.png">

    @* <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"> *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    @* Google font *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/css/css.css" rel="stylesheet" />
    <link href="~/css/header.css" rel="stylesheet" />
    <link href="~/css/footer.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Petshop_frontend.styles.css" asp-append-version="true" />
</head>
<body>

    @Html.Partial("_Header")

    <div class="main-content">
        @RenderBody()
    </div>

    @Html.Partial("_Footer")

    

    @* <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script> *@

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        // Lấy UserId từ Claim "UserId" của ông
        var rawUserId = "@(User.Identity.IsAuthenticated? User.FindFirst("UserId")?.Value : "0")";

        // Xóa session cũ nếu đã login (giữ lại logic cũ của ông)
        if (rawUserId !== "0") {
            localStorage.removeItem("ManaPet_Session");
        }

        window.chatConfig = {
            isLoggedIn: @(User.Identity.IsAuthenticated ? "true" : "false"),
            userId: rawUserId,
            userRole: "@(User.Identity.IsAuthenticated? User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value : "Guest")"
        };

        console.log("ChatConfig Loaded:", window.chatConfig); // Dòng này để ông F12 check cho sướng
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)


</body>
</html>


    

