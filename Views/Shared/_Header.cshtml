<header id="site-header" class="main-header sticky-top">
    <div class="container-fluid px-2 px-lg-5">
        <nav class="navbar navbar-expand-xl navbar-light py-2">
            <!-- Logo -->
            <a class="navbar-brand me-5" href="/">
                <img src="/Images/logo-mana-pet.png" alt="Mana Pet Logo" style="max-height: 80px; width: auto; object-fit: contain;">
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#manaNavbar" aria-controls="manaNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navigation Links -->
            <div class="collapse navbar-collapse" id="manaNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-xl-0 header-menu-list align-items-center">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/">
                            <i class="fas fa-home me-1"></i> Trang chủ
                        </a>
                    </li>
                    <li class="nav-item dropdown dropdown-hover">
                        <a class="nav-link dropdown-toggle fw-bold btn-glow-text" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-paw me-1"></i> Sản phẩm
                        </a>
                        <ul class="dropdown-menu dropdown-menu-custom shadow-sm border-0 border-radius-lg px-2 py-3" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item py-2 rounded" asp-controller="Product" asp-action="ChoCanh"><i class="fas fa-dog me-2 text-warning"></i> Chó cảnh</a></li>
                            <li><a class="dropdown-item py-2 rounded" asp-controller="Product" asp-action="MeoCanh"><i class="fas fa-cat me-2 text-warning"></i> Mèo cảnh</a></li>
                            <li><hr class="dropdown-divider opacity-25"></li>
                            <li><a class="dropdown-item py-2 rounded" href="/Products/Category/Food"><i class="fas fa-bone me-2 text-muted"></i> Thức ăn</a></li>
                            <li><a class="dropdown-item py-2 rounded" href="/Products/Category/Accessories"><i class="fas fa-hat-cowboy me-2 text-muted"></i> Phụ kiện</a></li>
                            <li><a class="dropdown-item py-2 rounded" href="/Products/Category/Bed"><i class="fas fa-bed me-2 text-muted"></i> Chuồng / Nhà / Đệm</a></li>
                            <li><a class="dropdown-item py-2 rounded" href="/Products/Category/Toys"><i class="fas fa-volleyball-ball me-2 text-muted"></i> Đồ chơi</a></li>
                            <li><a class="dropdown-item py-2 rounded" href="/Products/Category/Care"><i class="fas fa-bath me-2 text-muted"></i> Vệ sinh / chăm sóc</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Services">
                            <i class="fas fa-concierge-bell me-1"></i> Dịch vụ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/tin-tuc">
                            <i class="fas fa-newspaper me-1"></i> Tin tức
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/lien-he">
                            <i class="fas fa-envelope me-1"></i> Liên hệ
                        </a>
                    </li>
                </ul>

                <!-- Right Side Action Icons -->
                <div class="d-flex align-items-center header-right-actions flex-wrap gap-3 mt-3 mt-xl-0">
                    <!-- Search Box -->
                    <form class="d-flex position-relative header-search-form" action="/Products/Search" method="GET">
                        <input class="form-control rounded-pill ps-4 pe-5 border-0 bg-white shadow-sm" type="search" placeholder="Tìm kiếm bé yêu..." aria-label="Search" name="q" style="min-width: 250px;">
                        <button class="btn btn-search-icon position-absolute end-0 top-50 translate-middle-y border-0 bg-transparent text-muted" type="submit">
                            <i class="fas fa-search text-primary"></i>
                        </button>
                    </form>

                    <!-- Cart -->
                    <a href="/Cart" class="text-decoration-none position-relative cart-icon-wrapper text-dark mx-2">
                        <div class="cart-btn rounded-circle d-flex align-items-center justify-content-center bg-white shadow-sm" style="width: 45px; height: 45px; transition: 0.3s;">
                            <i class="fas fa-shopping-cart" style="color: var(--c-text);"></i>
                        </div>
                        <span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white">
                            0
                        </span>
                    </a>

                    <!-- Account / Login -->
                    <div class="account-action">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown dropdown-hover account-dropdown">
                                <a href="#" class="text-decoration-none text-dark d-flex align-items-center" id="accountDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="rounded-circle bg-white shadow-sm d-flex justify-content-center align-items-center me-2" style="width: 45px; height: 45px;">
                                        <i class="fas fa-user" style="color: var(--c-primary);"></i>
                                    </div>
                                    <span class="fw-bold fs-6 d-none d-xxl-inline">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 border-radius-lg px-2 py-2 mt-2" aria-labelledby="accountDropdown">
                                    <li><a class="dropdown-item py-2 rounded fw-bold" href="/User/Profile"><i class="fas fa-id-card me-2 text-primary"></i> Hồ sơ</a></li>
                                    <li><hr class="dropdown-divider opacity-25"></li>
                                    <li>
                                        <form asp-controller="User" asp-action="Logout" method="post" class="d-inline w-100 m-0 p-0">
                                            <button type="submit" class="dropdown-item py-2 rounded text-danger fw-bold"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="/User/Login" class="text-decoration-none d-flex align-items-center btn-login px-4 py-2 rounded-pill shadow-sm">
                                <i class="fas fa-user-circle me-2"></i> Đăng nhập
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </div>
</header>
