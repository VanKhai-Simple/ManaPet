@model Petshop_frontend.Models.Product

<style>
    /* Trạng thái khi kích hoạt thanh sticky */
    #sticky-buy-bar.show-bar {
        transform: translateY(0) !important;
        opacity: 1 !important;
    }

    /* Fix lỗi input number cho đẹp */
    .qty-input::-webkit-outer-spin-button,
    .qty-input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .qty-input:focus {
        outline: none;
        box-shadow: none;
    }

    /* Fix cứng: Dưới 768px (Mobile) là biến mất hoàn toàn, kể cả có class show-bar */
    @@media (max-width: 767.98px) {
        #sticky-buy-bar

    {
        display: none !important;
    }

    }

    /* Hiệu ứng ảnh bay vào giỏ hàng */
    .fly-item {
        position: fixed;
        z-index: 9999;
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 50%;
        transition: all 0.8s cubic-bezier(0.1, 0.5, 0.1, 1); /* Đường bay vòng cung nhẹ */
        pointer-events: none;
        border: 2px solid #ee4d2d;
    }

    /* Hiệu ứng rung nhẹ cái giỏ hàng khi nhận được hàng */
    .cart-shake {
        animation: shake 0.5s;
    }
    @@keyframes shake {
        0%

    {
        transform: scale(1);
    }

    25% {
        transform: scale(1.3);
    }

    50% {
        transform: scale(1.1);
    }

    100% {
        transform: scale(1);
    }

    }

    .cart-icon-wrapper:hover .cart-btn {
        background-color: var(--c-primary) !important;
        transform: translateY(-3px);
    }

    .cart-icon-wrapper:hover i {
        color: white !important;
    }
</style>

<div class="container py-4 bg-white" id="product-page-container"
     data-is-logged-in="@User.Identity.IsAuthenticated.ToString().ToLower()">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb bg-transparent p-0 small">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">TRANG CHỦ</a></li>
            <li class="breadcrumb-item"><a href="/cho-canh" class="text-decoration-none text-muted">@Model.Category?.CategoryName?.ToUpper()</a></li>
            <li class="breadcrumb-item active text-dark font-weight-bold">@Model.ProductName.ToUpper()</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-5 d-flex flex-row-reverse">
            <div class="main-image-wrapper border flex-grow-1 bg-light d-flex align-items-center justify-content-center" style="aspect-ratio: 1/1; overflow: hidden;">
                <img src="@Model.MainImage" id="mainImg" class="img-fluid" style="max-width: 100%; max-height: 100%; object-fit: contain;" data-zoom-image="@Model.MainImage">
            </div>

            <div class="thumb-column d-none d-md-flex flex-column gap-2 me-3" style="width: 80px;">
                <img src="@Model.MainImage" class="img-thumbnail thumb-item active" style="aspect-ratio:1/1; object-fit:cover; cursor:pointer;" onclick="changeImg('@Model.MainImage', this)">
                @foreach (var img in Model.ProductImages)
                {
                    <img src="@img.ImageUrl" class="img-thumbnail thumb-item" style="aspect-ratio:1/1; object-fit:cover; cursor:pointer;" onclick="changeImg('@img.ImageUrl', this)">
                }
            </div>
        </div>

        <div class="col-lg-4 px-lg-4">
            <h1 class="h3 font-weight-bold mb-3 text-uppercase">@Model.ProductName</h1>

            <div class="price-section py-3 border-top border-bottom mb-3">
                <span class="h4 text-dark font-weight-bold">Giá: </span>
                <span class="h4 text-danger font-weight-bold">
                    @if (Model.IsDiscount == true)
                    {
                        @(((decimal)(Model.DiscountPrice ?? 0)).ToString("N0"))
                    
                        <small>đ</small>
                        <del class="text-muted h6 ms-2">@(((decimal)Model.Price).ToString("N0"))đ</del>
                    }
                    else
                    {
                        @(((decimal)Model.Price).ToString("N0"))
                    
                        <small>đ</small>
                    }
                </span>
            </div>

            <div class="specs-grid border mb-3">
                <div class="row g-0">
                    <div class="col-6 p-2 border-end border-bottom small"><b>Tháng tuổi:</b> @Model.AgeMonths tháng</div>
                    <div class="col-6 p-2 border-bottom small"><b>Bố:</b> @Model.FatherInfo</div>
                    <div class="col-6 p-2 border-end border-bottom small"><b>Giới tính:</b> @(Model.Gender == true ? "Đực" : "Cái")</div>
                    <div class="col-6 p-2 border-bottom small"><b>Mẹ:</b> @Model.MotherInfo</div>
                    <div class="col-6 p-2 border-end border-bottom small"><b>Màu:</b> @Model.FurColor</div>
                    <div class="col-6 p-2 border-bottom small"><b>Sức khỏe:</b> @Model.HealthStatus</div>
                    <div class="col-6 p-2 border-end small"><b>Tình trạng:</b> @Model.Condition</div>
                    <div class="col-6 p-2 small"><b>Nguồn gốc:</b> @Model.Origin</div>
                </div>
            </div>

            <p class="small text-muted italic mb-4">
                Lưu ý: Giá có thể thay đổi tùy thời điểm. <b>Kết Bạn Zalo</b> để nhận thêm video thực tế của bé.
            </p>

            <div class="d-flex gap-2 mb-3 align-items-stretch" id="main-buy-trigger">
                <div class="input-group border w-auto shadow-sm">
                    <button class="btn btn-light btn-sm border-0 px-3 qty-minus" type="button">-</button>
                    <input type="number" value="1" min="1" class="form-control form-control-sm text-center border-0 qty-input" style="width: 50px; font-weight: bold;">
                    <button class="btn btn-light btn-sm border-0 px-3 qty-plus" type="button">+</button>
                </div>
                <button class="btn btn-primary flex-grow-1 font-weight-bold shadow-sm btn-add-to-cart">
                    <i class="fa fa-shopping-cart me-2"></i> ĐẶT MUA NGAY
                </button>
            </div>

            <div id="sticky-buy-bar" class="fixed-bottom d-none d-md-block mb-3" style="z-index: 1040; transition: all 0.4s ease; transform: translateY(150%); opacity: 0;">
                <div class="container d-flex justify-content-center">
                    <div class="bg-white border shadow-lg rounded-pill px-4 py-2 d-flex align-items-center gap-4 border-primary" style="min-width: 600px;">

                        <div class="d-flex align-items-center border-end pe-4">
                            <img src="@Model.MainImage" class="rounded-circle border" style="width: 45px; height: 45px; object-fit: cover;">
                            <div class="ms-3">
                                <h6 class="mb-0 font-weight-bold text-truncate" style="max-width: 150px;">@Model.ProductName</h6>
                                <span class="text-danger fw-bold small">@(((decimal)(Model.DiscountPrice ?? Model.Price)).ToString("N0"))đ</span>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <span class="small text-muted fw-bold">Số lượng:</span>
                            <div class="input-group border rounded-pill overflow-hidden" style="width: 110px;">
                                <button class="btn btn-light btn-sm border-0 qty-minus">-</button>
                                <input type="number" value="1" min="1" class="form-control form-control-sm text-center border-0 qty-input" style="font-weight: bold; background: transparent;">
                                <button class="btn btn-light btn-sm border-0 qty-plus">+</button>
                            </div>
                        </div>

                        <div class="ms-auto">
                            <button class="btn btn-primary rounded-pill px-4 font-weight-bold shadow-sm btn-add-to-cart">
                                <i class="fa fa-shopping-cart me-2"></i> ĐẶT MUA NGAY
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row g-2">
                <div class="col-6"><button class="btn btn-info btn-sm w-100 text-white font-weight-bold"><i class="fa fa-comment"></i> CHAT ZALO</button></div>
                <div class="col-6"><button class="btn btn-danger btn-sm w-100 font-weight-bold"><i class="fa fa-phone"></i> GỌI HOTLINE</button></div>
            </div>
        </div>

        <div class="col-lg-3">
            <div class="card bg-light border-0 rounded-0 shadow-sm">
                <div class="card-body">
                    <h6 class="font-weight-bold text-uppercase border-bottom pb-2 mb-3">Hệ thống cửa hàng</h6>
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-3"><i class="fa fa-map-marker text-danger"></i> <b>Cửa Hàng Hà Nội:</b><br>428 Minh Khai, Hai Bà Trưng.</li>
                        <li class="mb-3"><i class="fa fa-map-marker text-danger"></i> <b>Cửa Hàng TP.HCM:</b><br>961 Phạm Văn Đồng, Thủ Đức.</li>
                        <li class="mb-3"><i class="fa fa-paw text-warning"></i> <b>Trại giống:</b><br>Sóc Sơn, Hà Nội.</li>
                    </ul>
                    <div class="mt-3 text-center border-top pt-3">
                        <a href="tel:0123456789" class="h5 text-danger font-weight-bold text-decoration-none">0123.456.789</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <div class="accordion border-top" id="productAccordion">
                <div class="card border-0 border-bottom">
                    <div class="card-header bg-white p-0">
                        <button class="btn btn-link btn-block text-left text-dark font-weight-bold py-3 text-decoration-none w-100 d-flex justify-content-between align-items-center"
                                type="button" data-bs-toggle="collapse" data-bs-target="#collapseDesc">
                            MÔ TẢ CHI TIẾT <i class="fa fa-chevron-down"></i>
                        </button>
                    </div>
                    <div id="collapseDesc" class="collapse show" data-bs-parent="#productAccordion">
                        <div class="card-body">@Html.Raw(Model.FullDescription)</div>
                    </div>
                </div>

                <div class="card border-0 border-bottom">
                    <div class="card-header bg-white p-0">
                        <button class="btn btn-link btn-block text-left text-dark font-weight-bold py-3 text-decoration-none w-100 d-flex justify-content-between align-items-center collapsed"
                                type="button" data-bs-toggle="collapse" data-bs-target="#collapseBenefits">
                            QUYỀN LỢI KHI MUA TẠI PET HOUSE <i class="fa fa-chevron-down"></i>
                        </button>
                    </div>
                    <div id="collapseBenefits" class="collapse" data-bs-parent="#productAccordion">
                        <div class="card-body bg-light">
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2"><i class="fa fa-check text-success me-2"></i> Bảo hành thuần chủng trọn đời.</li>
                                <li class="mb-2"><i class="fa fa-check text-success me-2"></i> Bảo hành Care và Parvo 7 ngày.</li>
                                <li class="mb-2"><i class="fa fa-truck text-primary me-2"></i> Miễn phí vận chuyển toàn quốc (Tàu hỏa, xe khách).</li>
                                <li class="mb-2"><i class="fa fa-gift text-danger me-2"></i> Tặng kèm bộ phụ kiện 7 món khi về nhà mới.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="related-products mt-5">
        <h5 class="font-weight-bold text-uppercase border-bottom pb-2 mb-4">Sản phẩm tương tự</h5>
        <div class="row g-3">
            @foreach (var item in ViewBag.RelatedProducts as List<Petshop_frontend.Models.Product>)
            {
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100">
                        <a href="/Product/Details/@item.Id" class="text-decoration-none">
                            <img src="@item.MainImage" class="card-img-top" style="aspect-ratio:1/1; object-fit:cover;">
                            <div class="card-body text-center p-2">
                                <h6 class="text-dark mb-1 small font-weight-bold">@item.ProductName</h6>
                                <p class="text-danger mb-0 small">@(((decimal)item.Price).ToString("N0"))đ</p>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/elevatezoom/3.0.8/jquery.elevatezoom.min.js"></script>

    <script>
        $(document).ready(function() {
            // 1. Khởi tạo Zoom
            initZoom();

            // 2. Logic tăng giảm số lượng (Dùng Event Delegation để chắc chắn ăn sự kiện)
            $(document).on('click', '.qty-plus', function() {
                let input = $(this).closest('.input-group').find('.qty-input');
                input.val(parseInt(input.val()) + 1);
            });

            $(document).on('click', '.qty-minus', function() {
                let input = $(this).closest('.input-group').find('.qty-input');
                let val = parseInt(input.val());
                if (val > 1) input.val(val - 1);
            });

            // 3. Xử lý click ĐẶT MUA NGAY
            $(document).on('click', '.btn-add-to-cart', function(e) {
                e.preventDefault();
                const btn = $(this);

                // 1. Sửa lại selector cho đúng với HTML của ông giáo
                const cart = $('.cart-icon-wrapper').first();
                const badge = cart.find('.badge'); // Tìm cái badge nằm trong cart-icon-wrapper

                let imgToFly;
                if(btn.closest('#sticky-buy-bar').length > 0) {
                    imgToFly = btn.closest('#sticky-buy-bar').find('img');
                } else {
                    // Nếu ở trang chi tiết, lấy ảnh chính. Nếu ở trang danh sách, lấy ảnh của card đó
                    imgToFly = btn.closest('.card, .product-detail').find('img').first();
                    if(!imgToFly.length) imgToFly = $('#mainImg');
                }

                if (imgToFly.length && cart.length) {
                    // Tạo bản sao ảnh để bay
                    const flyImg = $('<img class="fly-item">');
                    flyImg.attr('src', imgToFly.attr('src'));

                    const startPos = imgToFly.offset();
                    const endPos = cart.offset();

                    $('body').append(flyImg);

                    // Vị trí bắt đầu
                    flyImg.css({
                        top: startPos.top,
                        left: startPos.left,
                        width: imgToFly.width() + 'px',
                        height: imgToFly.height() + 'px'
                    });

                    // Kích hoạt hiệu ứng bay sau 50ms
                    setTimeout(() => {
                        flyImg.css({
                            top: endPos.top + 10,
                            left: endPos.left + 10,
                            width: '20px',
                            height: '20px',
                            opacity: 0.2,
                            transform: 'rotate(360deg)' // Thêm xoay cho sinh động
                        });
                    }, 50);

                    setTimeout(() => {
                        flyImg.remove();

                        // Hiệu ứng rung giỏ hàng
                        cart.addClass('cart-shake');

                        // Lấy số lượng từ input (nếu có)
                        let addedQty = parseInt(btn.closest('div').find('.qty-input').val()) || 1;
                        let currentBadge = parseInt(badge.text()) || 0;

                        // Cập nhật số hiển thị tạm thời
                        badge.text(currentBadge + addedQty).fadeIn();

                        setTimeout(() => cart.removeClass('cart-shake'), 500);

                        // Gọi AJAX để lưu vào database
                        addToCartAjax(addedQty, badge);
                    }, 800);
                } else {
                    let addedQty = parseInt($('.qty-input').first().val()) || 1;
                    addToCartAjax(addedQty, badge);
                }
            });

            function addToCartAjax(qty, badgeElement) {
                const pid = '@Model.Id';
                $.post('@Url.Action("AddToCart", "Cart")', { productId: pid, quantity: qty }, function(res) {
                    if(res.success) {
                        // Cập nhật con số chuẩn từ Server trả về
                        badgeElement.text(res.newCount).fadeIn();
                    } else {
                        if(res.message === "Chưa login") {
                            alert("Vui lòng đăng nhập để mua hàng!");
                            window.location.href = '/User/Login?ReturnUrl=' + window.location.pathname;
                        }
                    }
                });
            }

            function initZoom() {
                if($(window).width() > 768) {
                    $('#mainImg').elevateZoom({
                        zoomType: "inner",
                        cursor: "crosshair"
                    });
                }
            }
        });

        function changeImg(src, el) {
            $('.zoomContainer').remove();
            $('#mainImg').removeData('elevateZoom');
            document.getElementById('mainImg').src = src;
            $('#mainImg').attr('data-zoom-image', src);

            // Khởi tạo lại zoom cho ảnh mới
            if($(window).width() > 768) {
                $('#mainImg').elevateZoom({ zoomType: "inner", cursor: "crosshair" });
            }

            $('.thumb-item').removeClass('active');
            $(el).addClass('active');
        }
    </script>
}