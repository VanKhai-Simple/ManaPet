@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container my-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 p-5">
                <div class="mb-4">
                    <i class="fas fa-check-circle text-success" style="font-size: 80px;"></i>
                </div>
                <h2 class="fw-bold text-success mb-3">ĐẶT HÀNG THÀNH CÔNG!</h2>
                <p class="text-muted mb-4">
                    Cảm ơn bạn đã mua sắm tại Pet House. Đơn hàng của bạn đang được xử lý.
                    Chúng tôi sẽ sớm liên hệ để giao những "bé cưng" hoặc phụ kiện đến bạn!
                </p>
                <div class="d-grid gap-2 d-md-block">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4 py-2 me-md-2">
                        <i class="fas fa-arrow-left me-2"></i> Tiếp tục mua sắm
                    </a>
                    @* Nếu ông có trang quản lý đơn hàng thì thay đổi link này *@
                    <a href="#" class="btn btn-primary rounded-pill px-4 py-2">
                        Xem đơn hàng <i class="fas fa-box ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>