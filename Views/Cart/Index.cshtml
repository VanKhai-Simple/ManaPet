@model List<Petshop_frontend.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    decimal totalCartMoney = 0;
}

<div class="container my-5">
    <div class="d-flex align-items-center mb-4">
        <h3 class="fw-bold mb-0"><i class="fas fa-shopping-basket text-primary me-2"></i>GIỎ HÀNG</h3>
        <span class="badge bg-secondary ms-3 rounded-pill">@(Model?.Count ?? 0) sản phẩm</span>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 border-0 shadow-sm rounded-4 bg-white">
            <img src="https://cdn-icons-png.flaticon.com/512/11329/11329073.png" alt="Empty Cart" style="width: 120px; opacity: 0.3;">
            <p class="mt-4 text-muted fs-5">Giỏ hàng của ông giáo đang trống trơn...</p>
            <a href="/" class="btn btn-primary rounded-pill px-5 py-2 fw-bold mt-2">ĐI MUA SẮM NGAY</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @* --- DANH SÁCH SẢN PHẨM --- *@
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="text-center py-3 border-0" style="width: 50px;">
                                        <input type="checkbox" id="check-all" class="form-check-input border-primary">
                                    </th>
                                    <th class="py-3 border-0">Sản phẩm</th>
                                    <th class="py-3 border-0" style="width: 120px;">Giá</th>
                                    <th class="py-3 border-0 text-center" style="width: 150px;">Số lượng</th>
                                    <th class="py-3 border-0" style="width: 130px;">Tổng</th>
                                    <th class="py-3 border-0" style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var price = item.Product?.IsDiscount == true ? item.Product.DiscountPrice : item.Product?.Price;
                                    var subTotal = (price ?? 0) * item.Quantity;

                                    <tr class="cart-item-row" data-product-id="@item.ProductId" data-price="@(price ?? 0)">
                                        @* 1. Cột Checkbox - Căn giữa *@
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input border-primary item-checkbox"
                                                   style="cursor: pointer; width: 19px; height: 19px;">
                                        </td>

                                        @* 2. Thông tin sản phẩm *@
                                        <td class="py-3">
                                            <div class="d-flex align-items-center">
                                                <img src="@item.Product?.MainImage" class="rounded-3 border shadow-sm" style="width: 70px; height: 70px; object-fit: cover;">
                                                <div class="ms-3">
                                                    <h6 class="mb-0 text-dark fw-bold" style="font-size: 0.95rem;">@item.Product?.ProductName</h6>
                                                    <small class="text-muted">Mã: #@item.ProductId</small>
                                                </div>
                                            </div>
                                        </td>

                                        @* 3. Đơn giá *@
                                        <td>
                                            <span class="fw-bold text-dark">@((price ?? 0).ToString("N0"))đ</span>
                                        </td>

                                        @* 4. Số lượng - Căn giữa *@
                                        <td>
                                            <div class="d-flex justify-content-center">
                                                <div class="input-group input-group-sm border rounded-pill overflow-hidden shadow-sm" style="width: 100px;">
                                                    <button type="button" class="btn btn-white border-0 py-1 btn-update-qty" data-change="-1">
                                                        <i class="fas fa-minus x-small text-muted"></i>
                                                    </button>
                                                    <input type="text" class="form-control text-center border-0 bg-transparent fw-bold qty-display p-0" value="@item.Quantity" readonly>
                                                    <button type="button" class="btn btn-white border-0 py-1 btn-update-qty" data-change="1">
                                                        <i class="fas fa-plus x-small text-muted"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </td>

                                        @* 5. Thành tiền *@
                                        <td>
                                            <span class="text-danger fw-bold subtotal-display">@(subTotal.ToString("N0"))đ</span>
                                        </td>

                                        @* 6. Nút xóa *@
                                        <td class="text-center pe-3">
                                            <form asp-action="Remove" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.ProductId" />
                                                <button type="submit" class="btn text-danger p-0 border-0"
                                                        onclick="return confirm('Xóa bé này khỏi giỏ nhé?')">
                                                    <i class="fas fa-times-circle fs-5"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @* --- TỔNG KẾT ĐƠN HÀNG --- *@
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 p-4 sticky-top" style="top: 100px;">
                    <h5 class="mb-4 fw-bold border-bottom pb-3 text-uppercase">Tóm tắt đơn hàng</h5>

                    <div class="d-flex justify-content-between mb-3 fs-6">
                        <span class="text-muted">Tạm tính:</span>
                        @* Để 0đ hoặc tính tổng Model tùy ý ông giáo *@
                        <span class="fw-bold" id="temp-total">0đ</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3 fs-6">
                        <span class="text-muted">Phí vận chuyển:</span>
                        <span class="text-success fw-bold">Miễn phí</span>
                    </div>

                    <div class="alert alert-info border-0 small py-2 mb-4">
                        <i class="fas fa-info-circle me-2"></i> Miễn phí ship toàn quốc cho mọi đơn hàng thú cưng.
                    </div>

                    <hr class="text-muted opacity-25">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="h5 mb-0 fw-bold">Tổng thanh toán:</span>
                        <span class="h4 mb-0 text-danger fw-bold" id="total-payment">0đ</span>
                    </div>

                    @* Thêm title để nhắc khách tích checkbox *@
                    <button type="button" id="btn-checkout"
                            class="btn btn-secondary btn-lg w-100 rounded-pill fw-bold shadow-sm mb-3 py-3"
                            disabled
                            title="Vui lòng chọn ít nhất một sản phẩm">
                        TIẾP TỤC THANH TOÁN <i class="fas fa-chevron-right ms-2"></i>
                    </button>

                    <a href="/" class="btn btn-outline-secondary w-100 rounded-pill py-2 border-0 small">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại mua thêm
                    </a>

                    @* Thêm một dòng nhắc nhỏ nếu giỏ hàng dài *@
                    <div id="selected-count-msg" class="text-center small text-muted mt-2" style="display:none;">
                        Đã chọn <span id="selected-count" class="fw-bold text-primary">0</span> sản phẩm
                    </div>

                    <div class="mt-3">
                        <p class="text-muted small">
                            Bạn muốn xem lại các đơn đã đặt?
                            <a asp-controller="Orders" asp-action="MyOrders" class="text-primary fw-bold">Xem lịch sử đơn hàng tại đây</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // 1. Hàm tính tổng tiền (Offline hoàn toàn)
            function calculateTotal() {
                let total = 0;
                let count = 0;

                $('.item-checkbox:checked').each(function () {
                    const row = $(this).closest('.cart-item-row');
                    // Dùng .data('price') vì row có thuộc tính data-price
                    const price = parseFloat(row.data('price')) || 0;
                    const qty = parseInt(row.find('.qty-display').val()) || 0;

                    const subtotal = price * qty;
                    total += subtotal;
                    count++;

                    // Cập nhật text thành tiền của từng dòng
                    row.find('.subtotal-display').text(subtotal.toLocaleString('vi-VN') + 'đ');
                });

                let formatted = total.toLocaleString('vi-VN') + 'đ';
                $('#temp-total').text(formatted);
                $('#total-payment').text(formatted);

                // Bật/tắt nút Checkout
                $('#btn-checkout').prop('disabled', count === 0)
                    .toggleClass('btn-secondary', count === 0)
                    .toggleClass('btn-primary', count > 0);
            }

            // 2. Nút tăng giảm số lượng (Chỉ sửa giao diện)
            $('.btn-update-qty').click(function (e) {
                e.preventDefault();
                const row = $(this).closest('.cart-item-row');
                const input = row.find('.qty-display');
                const change = parseInt($(this).data('change'));

                let currentQty = parseInt(input.val());
                let newQty = currentQty + change;

                if (newQty >= 1) {
                    input.val(newQty);
                    calculateTotal();
                }
            });

            // 3. Checkbox xử lý
            $('.item-checkbox, #select-all').change(function () {
                if ($(this).attr('id') === 'select-all') {
                    $('.item-checkbox').prop('checked', $(this).prop('checked'));
                } else {
                    // Tự động bỏ check "Select All" nếu có 1 món bị bỏ check
                    if ($('.item-checkbox:checked').length !== $('.item-checkbox').length) {
                        $('#select-all').prop('checked', false);
                    } else {
                        $('#select-all').prop('checked', true);
                    }
                }
                calculateTotal();
            });

            // 4. Khi bấm THANH TOÁN -> Gửi 1 request duy nhất (Gom đơn)
            $('#btn-checkout').click(function (e) {
                e.preventDefault();

                let cartData = [];
                let selectedIds = [];

                $('.item-checkbox:checked').each(function () {
                    const row = $(this).closest('.cart-item-row');
                    const pId = row.data('product-id');
                    const qty = parseInt(row.find('.qty-display').val());

                    cartData.push({
                        ProductId: pId,
                        Quantity: qty
                    });
                    selectedIds.push(pId);
                });

                if (cartData.length > 0) {
                    // Hiệu ứng loading cho pro
                    $(this).html('<span class="spinner-border spinner-border-sm"></span> Đang xử lý...');
                    $(this).prop('disabled', true);

                    $.ajax({
                        // Chú ý: URL này phải khớp với tên Action mới ở Controller (UpdateCartBeforeCheckout)
                        url: '/Cart/UpdateCartBeforeCheckout',
                        type: 'POST',
                        contentType: 'application/json; charset=utf-8', // BẮT BUỘC có cái này
                        data: JSON.stringify(cartData), // Chuyển mảng thành chuỗi JSON
                        success: function (res) {
                            if (res.success) {
                                // Chuyển hướng sang trang Checkout kèm theo danh sách ID
                                window.location.href = res.redirectUrl;
                            } else {
                                alert(res.message || "Có lỗi xảy ra khi cập nhật giỏ hàng.");
                                location.reload();
                            }
                        },
                        error: function () {
                            alert("Không thể kết nối với máy chủ.");
                            location.reload();
                        }
                    });
                }
            });
        });
    </script>
}
<style>
    body {
        background-color: #f8f9fa;
    }

    .cart-item-row {
        transition: all 0.2s ease;
    }

        .cart-item-row:hover {
            background-color: #fdfdfd;
        }

    .btn-white {
        background-color: #fff;
        color: #333;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }

    .rounded-4 {
        border-radius: 1rem !important;
    }
</style>