@model IEnumerable<Petshop_frontend.Models.Product>
@{
    ViewData["Title"] = "Kết quả tìm kiếm - " + ViewBag.SearchQuery;
    Layout = "~/Views/Shared/_Layout.cshtml";
    string query = ViewBag.SearchQuery as string;
}

<div class="cats-page-wrapper bg-bg pb-5">
    <!-- HERO SECTION -->
    <section class="page-hero bg-peach position-relative overflow-hidden py-5 mb-5">
        <div class="container position-relative z-1">
            <div class="row text-center text-md-start align-items-center">
                <div class="col-md-8 text-white py-4">
                    <h1 class="display-4 fw-black mb-3">Kết quả tìm kiếm</h1>
                    @if (!string.IsNullOrWhiteSpace(query))
                    {
                        <p class="lead fw-bold opacity-75 mb-0">Tìm thấy @Model.Count() kết quả cho từ khóa "<span class="text-dark">@query</span>"</p>
                    }
                    else
                    {
                        <p class="lead fw-bold opacity-75 mb-0">Hiển thị tất cả thú cưng.</p>
                    }
                </div>
            </div>
        </div>
        <div class="position-absolute end-0 bottom-0 opacity-25 w-50 h-100 d-none d-md-block" style="background: url('/Images/hero-pets.jpg') no-repeat center right / cover; clip-path: polygon(25% 0%, 100% 0%, 100% 100%, 0% 100%);"></div>
    </section>

    <!-- TRẢ VỀ RỖNG -->
    @if (!Model.Any())
    {
        <div class="container mb-5 text-center py-5">
            <i class="fas fa-search-minus display-1 text-muted mb-4 opacity-50"></i>
            <h3 class="fw-bold text-dark">Ôi không! Không tìm thấy thú cưng nào.</h3>
            <p class="text-muted">Chúng tôi không có bé yêu nào khớp với từ khóa "@query". Vui lòng thử lại với một cái tên hoặc giống khác.</p>
            <a href="/Products/Cats" class="btn btn-primary rounded-pill px-4 py-2 mt-3 fw-bold">Khám phá Danh sách Mèo cảnh</a>
        </div>
    }
    else
    {
        <!-- MẶT HÀNG GRID -->
        <section class="container mb-5 pb-4">
            <div class="row g-4">
                @foreach (var cat in Model)
                {
                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="card border-0 bg-white rounded-4 shadow-sm h-100 hover-lift position-relative overflow-hidden">
                            @if (cat.CreatedAt.HasValue && (DateTime.Now - cat.CreatedAt.Value).TotalDays < 14)
                            {
                                <div class="position-absolute px-3 py-1 bg-peach rounded-pill fw-bold fs-7 shadow-sm z-2" style="top: 15px; left: 15px;">Mới về</div>
                            }
                            else if (cat.StockQuantity < 20)
                            {
                                <div class="position-absolute px-3 py-1 bg-warning text-white rounded-pill fw-bold fs-7 shadow-sm z-2" style="top: 15px; left: 15px;">Nổi bật</div>
                            }

                            <div class="position-relative overflow-hidden" style="border-radius: 16px 16px 0 0;">
                                <img src="@cat.MainImage" class="w-100 object-fit-cover transition-transform blog-img" style="aspect-ratio: 1/1;" alt="@cat.ProductName">
                            </div>
                            <div class="card-body p-4 text-center">
                                <h5 class="card-title fw-black mb-2 text-dark">@(cat.Origin ?? cat.ProductName)</h5>
                                <div class="d-flex justify-content-center flex-wrap gap-2 mb-3">
                                    <span class="badge bg-light text-muted fw-bold rounded-pill border"><i class="fas fa-box-open fs-7"></i> Có sẵn: @cat.StockQuantity bé</span>
                                </div>
                                <h4 class="text-primary fw-black mb-4">@cat.Price.ToString("N0")₫</h4>
                                <div class="d-grid mt-auto">
                                    <a asp-action="Details" asp-route-id="@cat.Id" class="btn btn-outline-primary rounded-pill fw-bold py-2"><i class="fas fa-search me-2"></i> Xem chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
</div>
